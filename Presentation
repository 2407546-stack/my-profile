<style>
body, h1, h2, h3, p, ul, ol, table, th, td, form, input, textarea {
    margin: 0;
    padding: 0;
    font-family: Arial, sans-serif;
}

body {
    background: #f4f4f4;
    color: #333;
    line-height: 1.6;
    text-align: center;
}

header {
    background: #1a73e8;
    color: white;
    padding: 30px 10px;
}

header h1 {
    font-size: 2.2rem;
    margin-bottom: 10px;
}

nav {
    background: #eee;
    padding: 15px 10px;
    margin-bottom: 20px;
}

nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
}

nav a {
    text-decoration: none;
    color: #1a73e8;
    font-weight: bold;
}

nav a:hover {
    text-decoration: underline;
}

section {
    padding: 20px;
    max-width: 800px;
    margin: 0 auto 20px auto;
    background: white;
    border-radius: 8px;
    box-shadow: 0 0 8px rgba(0,0,0,0.1);
}

table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
}

th, td {
    border: 1px solid #ccc;
    padding: 8px;
}

ul, ol {
    margin-top: 10px;
    padding-left: 20px;
    text-align: left;
}

form input, form textarea {
    width: 80%;
    padding: 8px;
    margin-top: 5px;
    border-radius: 4px;
    border: 1px solid #ccc;
}

form input[type="submit"] {
    width: auto;
    background: #333;
    color: white;
    border: none;
    cursor: pointer;
    padding: 10px 20px;
}

form input[type="submit"]:hover {
    background: #1a73e8;
}

footer {
    background: #e53935;
    color: white;
    padding: 15px;
    margin-top: 20px;
}

@media (max-width: 600px) {
    nav ul {
        flex-direction: column;
        gap: 10px;
    }

    form input, form textarea {
        width: 100%;
    }
}
</style>
</head>

